<% content_for :title, "DQ RPG" %>

<div class="quest-shell">
  <header class="quest-hero">
    <p class="quest-kicker">DRAGON QUEST I STYLE</p>
    <h1>ドラゴンクエストI風ミニRPG</h1>
    <p class="quest-lead">
      町で装備を整え、洞窟の守り手を倒し、竜王を討ってアレフガルドに平和を取り戻してください。
    </p>
  </header>

  <main class="quest-grid" data-dragon-quest-game>
    <section class="quest-panel world-panel" aria-labelledby="world-panel-title">
      <div class="panel-heading">
        <div>
          <p class="panel-label">WORLD</p>
          <h2 id="world-panel-title">アレフガルド</h2>
        </div>
        <div class="mode-chip" id="dq-mode"></div>
      </div>
      <div class="location-line" id="dq-location"></div>
      <div class="world-stage">
        <div class="world-map" id="dq-map" aria-live="polite"></div>
        <div class="battle-overlay" id="dq-battle-overlay" aria-hidden="true" hidden>
          <div class="battle-overlay-shell">
            <div id="dq-enemy"></div>
            <div class="battle-overlay-ui" id="dq-battle-ui">
              <section class="battle-window battle-control-window" aria-labelledby="battle-command-title">
                <p class="panel-label">BATTLE</p>
                <h3 id="battle-command-title">こうどう</h3>
                <div id="dq-battle-status"></div>
                <div class="battle-actions">
                  <button class="command-button" data-command="attack" type="button">たたかう</button>
                  <button class="command-button" data-command="attack_spell" type="button" id="dq-attack-spell-button">ギラ</button>
                  <button class="command-button" data-command="heal_spell" type="button" id="dq-heal-spell-button">ホイミ</button>
                  <button class="command-button" data-command="defend" type="button">ぼうぎょ</button>
                  <button class="command-button" data-command="herb" type="button">やくそう</button>
                  <button class="command-button" data-command="run" type="button">にげる</button>
                </div>
              </section>

              <section class="battle-window battle-log-window" aria-labelledby="battle-log-title">
                <p class="panel-label">BATTLE LOG</p>
                <h3 id="battle-log-title">たたかいのきろく</h3>
                <ol id="dq-battle-log" class="log-list battle-log-list"></ol>
              </section>
            </div>
          </div>
        </div>
      </div>
      <p class="panel-footnote">移動: 方向キー / WASD 長押し</p>
      <p class="credits-note"><a href="/photo-credits.html" target="_blank" rel="noreferrer">写真出典</a></p>
    </section>

    <section class="quest-panel controls-panel" aria-labelledby="controls-panel-title">
      <div class="panel-heading">
        <div>
          <p class="panel-label">COMMAND</p>
          <h2 id="controls-panel-title">こうどう</h2>
        </div>
      </div>

      <div class="move-pad" aria-label="移動コマンド">
        <div></div>
        <button class="command-button" data-command="move" data-direction="up" type="button">↑</button>
        <div></div>
        <button class="command-button" data-command="move" data-direction="left" type="button">←</button>
        <button class="command-button action-button" data-command="action" type="button" id="dq-action-button">しらべる</button>
        <button class="command-button" data-command="move" data-direction="right" type="button">→</button>
        <div></div>
        <button class="command-button" data-command="move" data-direction="down" type="button">↓</button>
        <div></div>
      </div>

      <div id="dq-hero"></div>

      <section class="sound-panel" aria-labelledby="sound-panel-title">
        <div class="sound-row">
          <div>
            <p class="panel-label">SOUND</p>
            <h3 id="sound-panel-title">BGM</h3>
          </div>
          <button class="command-button sound-toggle-button" data-audio-command="toggle" type="button" id="dq-audio-toggle">BGM ON</button>
        </div>
        <p class="sound-status" id="dq-audio-status">最初の操作でBGMを開始します。</p>
      </section>

      <div class="reset-row">
        <button class="command-button reset-button" data-command="reset" type="button">新しい冒険を始める</button>
      </div>

      <div class="context-panel" id="dq-context"></div>
    </section>
  </main>
</div>
